# ╔══════════════════════════════════════════════════════════════════════╗
# ║     .env.example — نسخة للمشاركة في Git (بدون قيم حقيقية)           ║
# ║     انسخ هذا الملف إلى .env وأضف القيم الحقيقية                     ║
# ║     cp .env.example .env                                            ║
# ╚══════════════════════════════════════════════════════════════════════╝

# ── Flask Core ────────────────────────────────────────────────────────
# أنشئ مفتاحاً عشوائياً: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-here
FLASK_ENV=development

# ── Database ──────────────────────────────────────────────────────────
# Supabase (production) or SQLite (development)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── Supabase Public Keys (Frontend) ──────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key_here

# ── Google OAuth ──────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your-secret-here

# ── Gemini AI ─────────────────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key-here

# ── Redis (Production — مطلوب لـ Rate Limiting و Caching) ─────────────
REDIS_URL=redis://localhost:6379/0
RATELIMIT_STORAGE_URI=redis://localhost:6379/0

# ── Mail ──────────────────────────────────────────────────────────────
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password-here
MAIL_DEFAULT_SENDER=your-email@gmail.com
MAIL_ENABLED=True
ADMIN_EMAIL=admin@yourdomain.com

# ── Admin Account ─────────────────────────────────────────────────────
ADMIN_EMAIL=admin@atr.com
ADMIN_PASSWORD=your-strong-admin-password-here

# ── Database Pool (اختياري — للتحسين في Production) ──────────────────
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30

# ── CORS ──────────────────────────────────────────────────────────────
# في الـ Production: ضع نطاق الموقع الحقيقي فقط
CORS_ORIGINS=https://yourproductiondomain.com

# ── Rate Limiting ─────────────────────────────────────────────────────
RATELIMIT_ENABLED=True
RATELIMIT_DEFAULT=200 per day;50 per hour
